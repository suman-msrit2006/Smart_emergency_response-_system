# TrackER AI - Frontend Environment Variables Template
# Copy this file to .env.local for local development
# For production, set these in your hosting platform (Vercel)

#==========================================
# API CONFIGURATION
#==========================================
# Backend API URL (update with your deployed backend URL)
VITE_API_URL=https://your-backend-api.onrender.com/api

#==========================================
# SOCKET.IO CONFIGURATION
#==========================================
# WebSocket URL (same as backend URL without /api)
VITE_SOCKET_URL=https://your-backend-api.onrender.com

#==========================================
# LOCAL DEVELOPMENT
#==========================================
# For local development, use:
# VITE_API_URL=http://localhost:5000/api
# VITE_SOCKET_URL=http://localhost:5000
